server {
    listen 80;

    # Force Nginx to use Google's public DNS to resolve the external Render URL
    resolver 8.8.8.8 8.4.4.4 valid=30s;

    location / {
        # Using a variable forces dynamic runtime resolution instead of startup checks
        set $backend_target http://inventory-api-q4yl; 

        proxy_pass $backend_target;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
    }
}
