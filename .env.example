# Copy to .env and adjust as needed: cp .env.example .env

# PostgreSQL
DB_NAME=inventory_db
DB_USERNAME=postgres
DB_PASSWORD=inventory_secret
DB_PORT=5432

# Backend (host port – use 8088 if 8080 is already taken locally)
BACKEND_PORT=8088
DDL_AUTO=update
SHOW_SQL=false

# Frontend
FRONTEND_PORT=80

# Comma-separated origins allowed by the backend CORS config
CORS_ALLOWED_ORIGINS=http://localhost,http://localhost:80,http://localhost:4200
